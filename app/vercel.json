{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "api/debug.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "outputDirectory": "public",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/debug",
      "dest": "/api/debug.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "LOG_CHANNEL": "stderr",
    "CACHE_STORE": "array",
    "SESSION_DRIVER": "cookie",
    "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
    "VERCEL": "1"
  }
}
